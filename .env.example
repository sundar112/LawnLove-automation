# ── Target ────────────────────────────────────────────────────────────────
BASE_URL=https://lawn-love-frontend-ivory.vercel.app/
API_URL=http://localhost:3000/api

# ── Test users (NEVER put credentials in feature/spec files) ──────────────
# Required — the single tenant user that always exists
USER_EMAIL=tenant@example.com
USER_PASSWORD=your-tenant-password

# Optional — leave blank if no admin role exists in the app
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── Runner controls ───────────────────────────────────────────────────────
# WORKERS parallel tests; in headed mode each worker opens a browser window —
# use 1 locally while debugging, raise in CI headless runs.
HEADLESS=true
SLOW_MO=0
WORKERS=4
RETRIES=1
TRACE=on-first-retry         # off | on | retain-on-failure | on-first-retry
VIDEO=retain-on-failure      # off | on | retain-on-failure
SCREENSHOT=only-on-failure   # off | on | only-on-failure
DEFAULT_TIMEOUT_MS=15000
NAVIGATION_TIMEOUT_MS=30000
EXPECT_TIMEOUT_MS=10000

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=info               # trace | debug | info | warn | error | fatal

# ── Diagnostics ───────────────────────────────────────────────────────────
DEBUG_PROTOCOL=false
TRACE_NETWORK=false

# Optional: open Playwright Inspector after a test and hold until Resume (local debug only).
E2E_PAUSE_AFTER_TEST=false
