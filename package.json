{
  "name": "playwright-automation-template",
  "version": "0.1.0",
  "private": true,
  "description": "Reusable Playwright + TypeScript E2E automation template.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:smoke:headed": "cross-env HEADLESS=false playwright test --grep @smoke --headed --workers=1",
    "test:regression": "playwright test --grep @regression",
    "test:regression:headed": "cross-env HEADLESS=false playwright test --grep @regression --headed --workers=1",
    "test:ci": "playwright test --grep \"@smoke|@regression\"",
    "test:example": "playwright test src/tests/example.spec.ts",
    "test:example:headed": "cross-env HEADLESS=false playwright test src/tests/example.spec.ts --headed --workers=1",
    "test:example:smoke": "playwright test src/tests/example.spec.ts --grep @smoke",
    "test:example:regression": "playwright test src/tests/example.spec.ts --grep @regression",
    "test:home": "playwright test src/tests/home.spec.ts",
    "test:home:headed": "cross-env HEADLESS=false playwright test src/tests/home.spec.ts --headed --workers=1",
    "test:home:smoke": "playwright test src/tests/home.spec.ts --grep @smoke",
    "test:home:regression": "playwright test src/tests/home.spec.ts --grep @regression",
    "test:login": "playwright test src/tests/login.spec.ts",
    "test:login:headed": "cross-env HEADLESS=false playwright test src/tests/login.spec.ts --headed --workers=1",
    "test:login:smoke": "playwright test src/tests/login.spec.ts --grep @smoke",
    "test:login:regression": "playwright test src/tests/login.spec.ts --grep @regression",
    "test:signup": "playwright test src/tests/signup.spec.ts",
    "test:signup:headed": "cross-env HEADLESS=false playwright test src/tests/signup.spec.ts --headed --workers=1",
    "test:signup:smoke": "playwright test src/tests/signup.spec.ts --grep @smoke",
    "test:signup:regression": "playwright test src/tests/signup.spec.ts --grep @regression",
    "test:debug": "cross-env PWDEBUG=1 playwright test",
    "test:ui": "playwright test --ui",
    "codegen": "node scripts/codegen.mjs user",
    "codegen:admin": "node scripts/codegen.mjs admin",
    "codegen:public": "node scripts/codegen.mjs public",
    "report": "playwright show-report reports/playwright-report",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:no-sleeps": "node scripts/grep-bans.mjs",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rimraf reports auth/*.storage.json",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,cjs,mjs,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "imapflow": "^1.4.7",
    "ky": "^2.0.2",
    "mailparser": "^3.9.14",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.1",
    "eslint-plugin-playwright": "^2.10.2",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  }
}
